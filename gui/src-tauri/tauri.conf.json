{
  "productName": "Anthropic Provider Gateway Manager",
  "version": "0.2.0",
  "identifier": "com.anthropic.provider-gateway-gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "../../LICENSE",
    "resources": [
      "resources/proxy_server.py",
      "resources/config.json",
      "resources/requirements.txt",
      "resources/run.bat",
      "resources/run-logging.bat"
    ],
    "windows": {
      "wix": {
        "language": "ja-JP"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Anthropic Provider Gateway Manager",
        "width": 960,
        "height": 720,
        "resizable": true
      }
    ]
  }
}
