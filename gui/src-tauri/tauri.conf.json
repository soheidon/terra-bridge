{
  "productName": "Anthro Bridge",
  "version": "0.8.0",
  "identifier": "com.soheidon.anthro-bridge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "publisher": "Sohei IDE (soheidon)",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "../../LICENSE",
    "resources": [
      "resources/config.json"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "Japanese",
          "SimpChinese",
          "TradChinese",
          "Korean",
          "French"
        ],
        "installerHooks": "./windows/nsis/hooks.nsh"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Anthro Bridge",
        "width": 1100,
        "height": 680,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true
      }
    ]
  }
}
